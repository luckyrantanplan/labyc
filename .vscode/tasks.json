{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                ".cmake/build",
                "-G",
                "Ninja",
                "-DBUILD_TESTING=ON",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_COMPILER=g++-14",
                "-DLABYPATH_BUILD_TESTS=ON",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake Configure (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                ".cmake/build",
                "-G",
                "Ninja",
                "-DBUILD_TESTING=ON",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_CXX_COMPILER=g++-14",
                "-DLABYPATH_BUILD_TESTS=ON",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build C++",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                ".cmake/build",
                "--parallel"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": "CMake Configure (Debug)"
        },
        {
            "label": "Run C++ Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--output-on-failure",
                "--test-dir",
                ".cmake/build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Build C++",
            "problemMatcher": []
        },
        {
            "label": "Run Python Tests",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "pytest",
                "LabyPython/tests/",
                "-v"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Run All Tests",
            "dependsOn": [
                "Run C++ Tests",
                "Run Python Tests"
            ],
            "dependsOrder": "sequence",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Launch Python GUI",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "LabyPython.App"
            ],
            "options": {
                "cwd": "${workspaceFolder}/LabyPython/src",
                "env": {
                    "QT_QPA_PLATFORM": "xcb"
                }
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "clang-tidy",
            "type": "shell",
            "command": "clang-tidy",
            "args": [
                "-p",
                ".cmake/build",
                "${file}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "clang-format (current file)",
            "type": "shell",
            "command": "clang-format",
            "args": [
                "-i",
                "${file}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Docker: Build Production Image",
            "type": "shell",
            "command": "docker",
            "args": [
                "build",
                "-t",
                "labypath:latest",
                "."
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}